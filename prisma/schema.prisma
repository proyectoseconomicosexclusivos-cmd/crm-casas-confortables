enum WorkflowTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGE
  WORK_CREATED
  WORK_STATUS_CHANGE
  TASK_DUE_SOON
  TASK_OVERDUE
  TIME_BASED
  MANUAL
}

enum WorkflowAction {
  SEND_EMAIL
  SEND_WHATSAPP
  CREATE_TASK
  ASSIGN_LEAD
  UPDATE_STATUS
  CREATE_NOTIFICATION
  WEBHOOK
}

model Workflow {
