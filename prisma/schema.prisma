// ==========================================
// SISTEMA DE ALERTAS INTELIGENTES
// ==========================================

enum AlertType {
  LEAD_COLD       // Lead sin contacto
  LEAD_HOT        // Lead caliente sin seguimiento
  LOW_PERFORMANCE // Bajo rendimiento
  WORK_DELAY      // Obra retrasada
  PRODUCTION_SLOW // Producción lenta
  TASK_OVERDUE    // Tarea vencida
  COMMISSION_DUE  // Comisión pendiente
  SYSTEM          // Sistema
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id              String          @id @default(cuid())
  companyId       String?
  
  // Tipo y severidad
  type            AlertType
  severity        AlertSeverity   @default(WARNING)
  
  // Contenido
  title           String
  message         String
  
  // Referencia
  referenceType   String?         // lead, work, user, production, etc.
  referenceId     String?
  
  // Destinatarios
  targetUserId    String?         // Usuario específico
  targetRoleId    String?         // Rol específico
  isGlobal        Boolean         @default(false)
  
  // Estado
  isRead          Boolean         @default(false)
  readAt          DateTime?
  isResolved      Boolean         @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  
  // Notificaciones enviadas
  sentEmail       Boolean         @default(false)
  sentWhatsapp    Boolean         @default(false)
  sentTelegram    Boolean         @default(false)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([type])
  @@index([severity])
  @@index([companyId])
  @@index([targetUserId])
  @@index([createdAt])
}

model AlertRule {
  id              String          @id @default(cuid())
  companyId       String?
  
  // Datos de la regla
  name            String
  description     String?
  
  // Tipo de alerta
  type            AlertType
  severity        AlertSeverity   @default(WARNING)
  
  // Condiciones (JSON)
  conditions      String          // Ej: {"days_without_contact": 5}
  
  // Acciones
  notifyEmail     Boolean         @default(true)
  notifyWhatsapp  Boolean         @default(false)
  notifyTelegram  Boolean         @default(false)
  notifyPush      Boolean         @default(true)
  
  // Destinatarios
  notifyUser      Boolean         @default(true)  // Usuario afectado
  notifyManager   Boolean         @default(true)  // Su jefe
  notifyAdmin     Boolean         @default(false) // Admins
  
  // Estado
  isActive        Boolean         @default(true)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([type])
  @@index([companyId])
}

// ==========================================
// TIMELINE GLOBAL (TIPO CHAT)
