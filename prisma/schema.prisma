  totalCost       Float?
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  
  @@index([productionOrderId])
}

model Shipment {
  id              String          @id @default(cuid())
  productionOrderId String
  companyId       String
  
  // Datos del envío
  shipmentNumber  String          // Número de albarán
  driverName      String?
  driverPhone     String?
  vehicleRegistration String?     // Matrícula
  
  // Destino
  destinationName String?
  destinationAddress String?
  destinationCity String?
  destinationPostalCode String?
  
  // Estado
  status          String          @default("preparing") // preparing, loaded, in_transit, delivered
  
  // Fechas
  loadingDate     DateTime?
  shipmentDate    DateTime?
  deliveryDate    DateTime?
  
  // Contenido
  content         String?         // JSON con lista de contenido
