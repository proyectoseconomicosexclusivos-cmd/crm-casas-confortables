// ==========================================

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ExportFormat {
  CSV
  EXCEL
  PDF
  JSON
}

model ImportJob {
  id              String          @id @default(cuid())
  companyId       String
  userId          String
  
  // Datos del archivo
  fileName        String
  fileSize        Int
  fileUrl         String?
  
  // Tipo de importación
  entityType      String          // leads, users, clients, etc.
  
  // Mapeo de columnas
  columnMapping   String?         // JSON con mapeo
  
  // Estado
  status          ImportStatus    @default(PENDING)
  totalRows       Int             @default(0)
  processedRows   Int             @default(0)
  successRows     Int             @default(0)
  errorRows       Int             @default(0)
  
  // Errores
