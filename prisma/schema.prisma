// CRM SaaS - Casas Confortables
// Schema completo para sistema multi-tenant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEAM_LEADER
  ARCHITECT      // Arquitecto - sube proyectos y planos
  COMMERCIAL
  FRANCHISE
  REAL_ESTATE
  SUBCONTRACTOR
  WORKER
  CLIENT
}

enum LeadStatus {
  NEW           // Nuevo
  CONTACTED     // Contactado
  VISIT         // Visita programada
  OFFER         // Oferta enviada
  NEGOTIATION   // En negociación
  CLOSED        // Cerrado (ganado)
  LOST          // Perdido
}

enum LeadType {
  NEW_BUILD     // Obra nueva
  REFORM        // Reforma
  INVESTMENT    // Inversión
  FRANCHISE     // Franquicia
  OTHER         // Otro
}

enum LeadSource {
  WEB           // Web propia
  FACEBOOK      // Facebook
  INSTAGRAM     // Instagram
  GOOGLE        // Google Ads
  REFERRAL      // Recomendación
  REAL_ESTATE   // Inmobiliaria
  COLD_CALL     // Llamada en frío
  FAIR          // Feria/evento
  OTHER         // Otro
}

enum WorkStatus {
  PLANNING      // Planificación
  IN_PROGRESS   // En curso
  PAUSED        // Pausada
  COMPLETED     // Completada
  CANCELLED     // Cancelada
}

enum CompanyType {
  FRANCHISE     // Franquicia
  REAL_ESTATE   // Inmobiliaria
  SUBCONTRACTOR // Subcontrata
  PARTNER       // Socio colaborador
  OWN           // Empresa propia
}

enum AssignmentMethod {
  ROUND_ROBIN   // Round Robin
  BY_ZONE       // Por zona
  BY_LOAD       // Por carga de trabajo
  BY_TYPE       // Por tipo de lead
  MANUAL        // Manual
}

enum NotificationType {
  LEAD_ASSIGNED
  LEAD_UPDATED
  NEW_COMMENT
  WORK_UPDATE
  TASK_REMINDER
  SYSTEM
}

enum DocumentType {
  CONTRACT
  BUDGET
  INVOICE
  CERTIFICATE
  PHOTO
  VIDEO
  PLAN
  OTHER
}

// ==========================================
// USUARIOS Y AUTENTICACIÓN
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String    // Hash bcrypt
  name          String
  lastName      String?
  phone         String?
  avatar        String?   // URL del avatar
  role          UserRole  @default(COMMERCIAL)
  isActive      Boolean   @default(true)
  
  // Relaciones organizativas
  companyId     String?
  officeId      String?
  teamId        String?
  managerId     String?   // Jefe directo
  
  // Configuración
  timezone         String    @default("Europe/Madrid")
  language         String    @default("es")
  emailNotifications Boolean @default(true)
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // Relaciones
  company       Company?  @relation(fields: [companyId], references: [id])
  office        Office?   @relation(fields: [officeId], references: [id])
  team          Team?     @relation(fields: [teamId], references: [id])
  manager       User?     @relation("TeamMembers", fields: [managerId], references: [id])
  teamMembers   User[]    @relation("TeamMembers")
  
  // Leads asignados
  assignedLeads    Lead[]      @relation("AssignedLeads")
  createdLeads     Lead[]      @relation("CreatedLeads")
  leadComments     LeadComment[]
  leadActivities   LeadActivity[]
  
  // Documentos
  documents        Document[]
  
  // Obras
  works            Work[]      @relation("CreatedWorks")
  workUpdates      WorkUpdate[]
  
  // Tareas
  tasks            Task[]
  assignedTasks    Task[]      @relation("AssignedTasks")
  
  // Notificaciones
  notifications    Notification[]
  
  // Logs
  activityLogs     ActivityLog[]
  
  // Presupuestos
  budgets          Budget[]
  
  // Configuración de reparto
  assignmentConfig AssignmentConfig?
  
  // Sesiones y cuentas
  sessions         Session[]
  accounts         Account[]
  
  // Certificaciones de empleado
  employeeCertifications EmployeeCertification[]
  
  // Análisis de documentos
  documentAnalyses DocumentAnalysis[]
  
  // Biblioteca de documentos
  libraryDocuments DocumentLibrary[]
  
  // Contratos firmados
  signedContracts Contract[] @relation("ContractsSignedByUser")
  
  @@index([email])
  @@index([role])
  @@index([companyId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
  @@index([userId])
}

model Account {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // google, facebook, etc.
  providerId   String
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerId])
  @@index([userId])
}

// ==========================================
// ESTRUCTURA ORGANIZATIVA
// ==========================================

model Company {
  id            String        @id @default(cuid())
  name          String
  type          CompanyType   @default(FRANCHISE)
  taxId         String?       // CIF/NIF
  email         String?
  phone         String?
  website       String?
  address       String?
  city          String?
  province      String?
  postalCode    String?
  country       String        @default("España")
  
  // Configuración
  logo          String?       // URL del logo
  primaryColor  String?       // Color primario para personalización
  isActive      Boolean       @default(true)
  
  // Configuración de reparto de leads
  assignmentMethod  AssignmentMethod @default(ROUND_ROBIN)
  
  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relaciones
  users         User[]
  offices       Office[]
  leads         Lead[]
  documents     Document[]
  works         Work[]
  budgets       Budget[]
  templates     DocumentTemplate[]
  assignmentRules AssignmentRule[]
  
  // Catálogos y pedidos
  productCategories     ProductCategory[]
  materialProducts      MaterialProduct[]
  merchProducts         MerchProduct[]
  materialOrders        MaterialOrder[]
  merchOrders           MerchOrder[]
  certifications        Certification[]
  subcontractorBudgets  SubcontractorBudget[]
  profitShares          ProfitShare[]
  catalogImports        CatalogImport[]
  
  // Nuevos módulos
  employeeCertifications EmployeeCertification[]
  contracts              Contract[]
  documentLibrary        DocumentLibrary[]
  documentAnalyses       DocumentAnalysis[]
  externalLinks          ExternalLink[]
  
  @@index([type])
}

model Office {
  id            String      @id @default(cuid())
  companyId     String
  name          String
  code          String?     // Código de oficina
  email         String?
  phone         String?
  address       String?
  city          String?
  province      String?
  postalCode    String?
  
  // Zonas de cobertura
  zones         String?     // JSON con lista de zonas/códigos postales
  
  // Configuración
  isActive      Boolean     @default(true)
  
  // Timestamps
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relaciones
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  teams         Team[]
  users         User[]
  leads         Lead[]
  
  @@index([companyId])
}

model Team {
  id            String      @id @default(cuid())
  officeId      String
  name          String
  description   String?
  
  // Configuración
  isActive      Boolean     @default(true)
  
  // Timestamps
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relaciones
  office        Office      @relation(fields: [officeId], references: [id], onDelete: Cascade)
  users         User[]
  leads         Lead[]
  
  @@index([officeId])
}

// ==========================================
// LEADS (CORE DEL SISTEMA)
// ==========================================

model Lead {
  id            String      @id @default(cuid())
  
  // Datos del lead
  firstName     String
  lastName      String
  email         String?
  phone         String
  alternativePhone String?
  
  // Ubicación
  address       String?
  city          String?
  province      String?
  postalCode    String?
  zone          String?     // Zona asignada
  
  // Clasificación
  type          LeadType    @default(NEW_BUILD)
  source        LeadSource  @default(WEB)
  status        LeadStatus  @default(NEW)
  
  // Valoración
  estimatedValue    Float?  // Valor estimado
  probability       Int?    @default(50) // Probabilidad de cierre 0-100
  priority          Int     @default(3)  // 1=Alta, 2=Media, 3=Baja
  
  // Descripción
  description   String?     // Notas principales
  requirements  String?     // Requisitos específicos
  
  // Presupuesto del cliente
  budgetMin     Float?
  budgetMax     Float?
  
  // Fechas importantes
  preferredStartDate DateTime?
  deadline          DateTime?
  
  // Relaciones organizativas
  companyId     String
  officeId      String?
  teamId        String?
  assignedToId  String?     // Comercial asignado
  createdById   String      // Usuario que creó el lead
  
  // Cliente convertido
  clientId      String?     // Si se convirtió en cliente
  
  // Información adicional
  customFields  String?     // JSON con campos personalizados
  
  // Timestamps
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  contactedAt   DateTime?   // Última fecha de contacto
  closedAt      DateTime?   // Fecha de cierre
  
  // Relaciones
  company       Company     @relation(fields: [companyId], references: [id])
  office        Office?     @relation(fields: [officeId], references: [id])
  team          Team?       @relation(fields: [teamId], references: [id])
  assignedTo    User?       @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdBy     User        @relation("CreatedLeads", fields: [createdById], references: [id])
  
  // Historial y seguimiento
  comments      LeadComment[]
  activities    LeadActivity[]
  documents     Document[]
  tasks         Task[]
  budgets       Budget[]
  
  // Obra asociada
  work          Work?
  
  @@index([status])
  @@index([type])
  @@index([companyId])
  @@index([assignedToId])
  @@index([createdAt])
}

model LeadComment {
  id            String      @id @default(cuid())
  leadId        String
  userId        String
  content       String
  
  // Timestamps
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relaciones
  lead          Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])
  
  @@index([leadId])
  @@index([userId])
}

model LeadActivity {
  id            String      @id @default(cuid())
  leadId        String
  userId        String?
  
  // Tipo de actividad
  action        String      // created, updated, status_change, assigned, comment, etc.
  description   String
  oldValue      String?     // Valor anterior (para cambios de estado)
  newValue      String?     // Valor nuevo
  
  // Metadata
  metadata      String?     // JSON con información adicional
  
  // Timestamp
  createdAt     DateTime    @default(now())
  
  // Relaciones
  lead          Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id])
  
  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
}

// ==========================================
// CONFIGURACIÓN DE REPARTO DE LEADS
// ==========================================

model AssignmentConfig {
  id              String          @id @default(cuid())
  userId          String          @unique
  maxLeads        Int             @default(50)    // Máximo de leads activos
  currentLeads    Int             @default(0)     // Leads actuales asignados
  weight          Int             @default(1)     // Peso para distribución
  isActive        Boolean         @default(true)  // Si recibe leads
  
  // Zonas asignadas
  zones           String?         // JSON con zonas
  
  // Tipos de lead que acepta
  acceptedTypes   String?         // JSON con tipos aceptados
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AssignmentRule {
  id              String          @id @default(cuid())
  companyId       String
  name            String
  description     String?
  
  // Condiciones (JSON)
  conditions      String          // Ej: {"zone": "Madrid", "type": "NEW_BUILD"}
  
  // Acción
  method          AssignmentMethod
  targetUserId    String?         // Para asignación manual directa
  targetTeamId    String?
  targetOfficeId  String?
  
  // Prioridad
  priority        Int             @default(0)     // Mayor prioridad = se aplica primero
  
  // Estado
  isActive        Boolean         @default(true)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([priority])
}

// ==========================================
// PRESUPUESTOS
// ==========================================

model Budget {
  id              String      @id @default(cuid())
  leadId          String
  companyId       String
  createdById     String
  
  // Datos del presupuesto
  number          String?     // Número de presupuesto
  title           String
  description     String?
  
  // Importes
  subtotal        Float       @default(0)
  tax             Float       @default(0)
  taxRate         Float       @default(21)
  total           Float       @default(0)
  
  // Validez
  validUntil      DateTime?
  
  // Estado
  status          String      @default("draft") // draft, sent, accepted, rejected
  
  // Contenido (JSON con líneas de presupuesto)
  lines           String?     // JSON con las líneas del presupuesto
  
  // PDF generado
  pdfUrl          String?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  sentAt          DateTime?
  acceptedAt      DateTime?
  
  // Relaciones
  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company         Company     @relation(fields: [companyId], references: [id])
  createdBy       User        @relation(fields: [createdById], references: [id])
  
  @@index([leadId])
  @@index([companyId])
}

// ==========================================
// DOCUMENTOS
// ==========================================

model Document {
  id              String        @id @default(cuid())
  companyId       String
  uploadedById    String
  
  // Relación polimórfica
  leadId          String?
  workId          String?
  
  // Datos del documento
  name            String
  description     String?
  type            DocumentType  @default(OTHER)
  
  // Archivo
  fileName        String
  filePath        String        // URL o ruta del archivo
  fileSize        Int?
  mimeType        String?
  
  // Metadatos
  tags            String?       // JSON con tags
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relaciones
  company         Company       @relation(fields: [companyId], references: [id])
  uploadedBy      User          @relation(fields: [uploadedById], references: [id])
  lead            Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  work            Work?         @relation(fields: [workId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([leadId])
  @@index([workId])
  @@index([type])
}

model DocumentTemplate {
  id              String        @id @default(cuid())
  companyId       String
  name            String
  description     String?
  type            DocumentType
  
  // Contenido
  content         String?       // HTML o contenido base
  variables       String?       // JSON con variables disponibles
  
  // Estado
  isActive        Boolean       @default(true)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relaciones
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([type])
}

// ==========================================
// OBRAS
// ==========================================

model Work {
  id              String      @id @default(cuid())
  leadId          String      @unique
  companyId       String
  createdById     String      // Usuario que creó la obra
  
  // Datos de la obra
  name            String
  description     String?
  reference       String?     // Referencia interna
  
  // Ubicación
  address         String
  city            String?
  province        String?
  postalCode      String?
  
  // Estado y fechas
  status          WorkStatus  @default(PLANNING)
  startDate       DateTime?
  endDate         DateTime?
  estimatedDays   Int?
  
  // Presupuesto
  budget          Float?
  actualCost      Float?
  
  // Progreso
  progress        Int         @default(0)   // 0-100
  
  // Notas
  notes           String?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relaciones
  lead            Lead        @relation(fields: [leadId], references: [id])
  company         Company     @relation(fields: [companyId], references: [id])
  createdBy       User        @relation("CreatedWorks", fields: [createdById], references: [id])
  
  // Subcontratas asignadas
  subcontractors  WorkSubcontractor[]
  
  // Actualizaciones
  updates         WorkUpdate[]
  
  // Documentos
  documents       Document[]
  
  // Incidencias
  incidents       Incident[]
  
  // Tareas
  tasks           Task[]
  
  // Módulo de subcontratas
  subcontractorTasks       SubcontractorTask[]
  paymentPhases            SubcontractorPaymentPhase[]
  subcontractorAdvances    SubcontractorAdvance[]
  subcontractorWorkLogs    SubcontractorWorkLog[]
  materialDeliveries       MaterialDelivery[]
  
  // Nuevos módulos
  materialOrders           MaterialOrder[]
  certifications           Certification[]
  subcontractorBudgets     SubcontractorBudget[]
  budgetComparisons        BudgetComparison[]
  profitShares             ProfitShare[]
  
  @@index([companyId])
  @@index([status])
  @@index([leadId])
  @@index([createdById])
}

model WorkSubcontractor {
  id              String      @id @default(cuid())
  workId          String
  subcontractorId String     // UserId del subcontratista
  
  // Datos de la asignación
  role            String?     // Rol en la obra (electricista, fontanero, etc.)
  description     String?
  
  // Fechas
  startDate       DateTime?
  endDate         DateTime?
  
  // Estado
  status          String      @default("assigned") // assigned, in_progress, completed
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relaciones
  work            Work        @relation(fields: [workId], references: [id], onDelete: Cascade)
  
  @@index([workId])
  @@index([subcontractorId])
}

model WorkUpdate {
  id              String      @id @default(cuid())
  workId          String
  userId          String
  
  // Contenido
  title           String
  description     String
  
  // Progreso
  progressBefore  Int?
  progressAfter   Int?
  
  // Archivos multimedia
  photos          String?     // JSON con URLs de fotos
  videos          String?     // JSON con URLs de videos
  
  // Timestamp
  createdAt       DateTime    @default(now())
  
  // Relaciones
  work            Work        @relation(fields: [workId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id])
  
  @@index([workId])
  @@index([userId])
  @@index([createdAt])
}

model Incident {
  id              String      @id @default(cuid())
  workId          String
  reportedById    String
  
  // Datos de la incidencia
  title           String
  description     String
  severity        String      @default("medium") // low, medium, high, critical
  
  // Estado
  status          String      @default("open") // open, in_progress, resolved, closed
  
  // Resolución
  resolution      String?
  resolvedAt      DateTime?
  resolvedById    String?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relaciones
  work            Work        @relation(fields: [workId], references: [id], onDelete: Cascade)
  
  @@index([workId])
  @@index([status])
  @@index([severity])
}

// ==========================================
// TAREAS
// ==========================================

model Task {
  id              String      @id @default(cuid())
  
  // Relación polimórfica
  leadId          String?
  workId          String?
  
  // Datos de la tarea
  title           String
  description     String?
  
  // Asignación
  createdById     String
  assignedToId    String?
  
  // Fechas
  dueDate         DateTime?
  completedAt     DateTime?
  
  // Prioridad y estado
  priority        String      @default("medium") // low, medium, high
  status          String      @default("pending") // pending, in_progress, completed, cancelled
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relaciones
  lead            Lead?       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  work            Work?       @relation(fields: [workId], references: [id], onDelete: Cascade)
  createdBy       User        @relation(fields: [createdById], references: [id])
  assignedTo      User?       @relation("AssignedTasks", fields: [assignedToId], references: [id])
  
  @@index([leadId])
  @@index([workId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
}

// ==========================================
// NOTIFICACIONES
// ==========================================

model Notification {
  id              String            @id @default(cuid())
  userId          String
  
  // Tipo y contenido
  type            NotificationType
  title           String
  message         String
  
  // Referencia (opcional)
  referenceType   String?           // lead, work, task, etc.
  referenceId     String?
  
  // Estado
  isRead          Boolean           @default(false)
  readAt          DateTime?
  
  // Canales
  sentEmail       Boolean           @default(false)
  sentWhatsapp    Boolean           @default(false)
  
  // Timestamp
  createdAt       DateTime          @default(now())
  
  // Relaciones
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==========================================
// LOGS DE ACTIVIDAD
// ==========================================

model ActivityLog {
  id              String      @id @default(cuid())
  userId          String?
  
  // Acción
  action          String      // login, logout, create_lead, update_lead, etc.
  entity          String?     // lead, user, work, etc.
  entityId        String?
  
  // Detalles
  description     String
  ipAddress       String?
  userAgent       String?
  
  // Cambios (JSON)
  oldValue        String?
  newValue        String?
  
  // Timestamp
  createdAt       DateTime    @default(now())
  
  // Relaciones
  user            User?       @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ==========================================
// CONFIGURACIÓN DEL SISTEMA
// ==========================================

model SystemConfig {
  id              String      @id @default(cuid())
  key             String      @unique
  value           String
  description     String?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ==========================================
// ESTADÍSTICAS AGREGADAS (para dashboards)
// ==========================================

model DailyStats {
  id              String      @id @default(cuid())
  date            DateTime
  companyId       String?
  officeId        String?
  userId          String?
  
  // Métricas de leads
  newLeads        Int         @default(0)
  contactedLeads  Int         @default(0)
  visitedLeads    Int         @default(0)
  offeredLeads    Int         @default(0)
  closedLeads     Int         @default(0)
  lostLeads       Int         @default(0)
  
  // Valores
  totalValue      Float       @default(0)
  closedValue     Float       @default(0)
  
  // Timestamp
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@unique([date, companyId, officeId, userId])
  @@index([date])
  @@index([companyId])
  @@index([userId])
}

// ==========================================
// MÓDULO DE FÁBRICA / PRODUCCIÓN
// ==========================================

enum ProductionOrderStatus {
  PENDING       // Pendiente
  IN_PROGRESS   // En producción
  QUALITY_CHECK // Control de calidad
  READY         // Listo para envío
  SHIPPED       // Enviado
  DELIVERED     // Entregado
  CANCELLED     // Cancelado
}

enum ProductionPhase {
  CUTTING       // Corte
  ASSEMBLY      // Ensamblaje
  WELDING       // Soldadura
  PAINTING      // Pintura
  FINISHING     // Acabado
  QUALITY       // Control de calidad
  PACKAGING     // Embalaje
}

model ProductionOrder {
  id              String                @id @default(cuid())
  companyId       String
  workId          String?               // Obra relacionada (opcional)
  leadId          String?               // Lead relacionado (opcional)
  
  // Datos del pedido
  orderNumber     String                // Número de pedido interno
  reference       String?               // Referencia externa
  name            String                // Nombre del pedido
  description     String?
  
  // Cliente
  clientName      String?
  clientPhone     String?
  clientAddress   String?
  clientCity      String?
  
  // Estado y prioridad
  status          ProductionOrderStatus @default(PENDING)
  priority        Int                   @default(3)  // 1=Urgente, 2=Alta, 3=Normal, 4=Baja
  currentPhase    ProductionPhase?
  
  // Fechas
  orderDate       DateTime              @default(now())
  dueDate         DateTime?
  startDate       DateTime?
  completedDate   DateTime?
  shippedDate     DateTime?
  deliveredDate   DateTime?
  
  // Cantidades y medidas
  quantity        Int                   @default(1)
  unit            String?               // unidad, m2, ml, etc.
  dimensions      String?               // JSON con dimensiones
  weight          Float?                // Peso en kg
  
  // Costes
  estimatedCost   Float?
  actualCost      Float?
  
  // Progreso
  progress        Int                   @default(0)  // 0-100
  
  // Notas
  notes           String?
  internalNotes   String?
  
  // Timestamps
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  
  // Relaciones
  activities      ProductionActivity[]
  materials       ProductionMaterial[]
  shipments       Shipment[]
  timeline        ProductionTimeline[]
  photos          ProductionPhoto[]
  
  @@index([companyId])
  @@index([status])
  @@index([orderDate])
  @@index([dueDate])
}

model ProductionActivity {
  id              String          @id @default(cuid())
  productionOrderId String
  
  // Datos de la actividad
  userId          String?         // Trabajador
  phase           ProductionPhase
  activity        String          // Qué se hizo
  description     String?
  
  // Tiempos
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?            // Duración calculada
  
  // Cantidad producida
  quantity        Int?
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  
  @@index([productionOrderId])
  @@index([userId])
  @@index([createdAt])
}

model ProductionMaterial {
  id              String          @id @default(cuid())
  productionOrderId String
  
  // Datos del material
  name            String
  description     String?
  code            String?         // Código interno
  
  // Cantidades
  quantityUsed    Float
  unit            String          // kg, m, unidades, etc.
  unitCost        Float?
  totalCost       Float?
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  
  @@index([productionOrderId])
}

model Shipment {
  id              String          @id @default(cuid())
  productionOrderId String
  companyId       String
  
  // Datos del envío
  shipmentNumber  String          // Número de albarán
  driverName      String?
  driverPhone     String?
  vehicleRegistration String?     // Matrícula
  
  // Destino
  destinationName String?
  destinationAddress String?
  destinationCity String?
  destinationPostalCode String?
  
  // Estado
  status          String          @default("preparing") // preparing, loaded, in_transit, delivered
  
  // Fechas
  loadingDate     DateTime?
  shipmentDate    DateTime?
  deliveryDate    DateTime?
  
  // Contenido
  content         String?         // JSON con lista de contenido
  notes           String?
  
  // Fotos
  photos          String?         // JSON con URLs de fotos de carga
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])
  
  @@index([companyId])
  @@index([productionOrderId])
  @@index([status])
}

model ProductionTimeline {
  id              String          @id @default(cuid())
  productionOrderId String
  userId          String?
  
  // Evento
  event           String          // created, status_change, phase_change, note, etc.
  description     String
  oldValue        String?
  newValue        String?
  
  // Metadata
  metadata        String?         // JSON con información adicional
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  
  @@index([productionOrderId])
  @@index([createdAt])
}

model ProductionPhoto {
  id              String          @id @default(cuid())
  productionOrderId String
  uploadedById    String
  
  // Datos de la foto
  title           String?
  description     String?
  url             String          // URL de la imagen
  
  // Tipo
  type            String          @default("production") // production, quality, loading, delivery
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  
  @@index([productionOrderId])
  @@index([type])
}

