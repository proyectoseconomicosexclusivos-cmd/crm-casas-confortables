enum CommissionStatus {
  PENDING        // Pendiente de cobro
  APPROVED       // Aprobada
  PAID           // Pagada
  CANCELLED      // Cancelada
}

enum CommissionType {
  SALE           // Por venta
  MARGIN         // Por margen
  REFERRAL       // Por referido
  BONUS          // Bonus extra
  FRANCHISE      // Franquicia
  REAL_ESTATE    // Inmobiliaria
}

model CommissionConfig {
  id              String          @id @default(cuid())
  companyId       String
  
  // Ámbito de la comisión
  userId          String?         // Para comercial específico
  roleId          String?         // Para rol (COMMERCIAL, FRANCHISE, etc.)
  
