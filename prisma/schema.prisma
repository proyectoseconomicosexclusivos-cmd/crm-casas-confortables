  timingScore     Int             @default(0)  // Timing
  sourceScore     Int             @default(0)  // Fuente
  profileScore    Int             @default(0)  // Perfil del cliente
  
  // Predicciones
  predictedCloseDate DateTime?
  predictedValue     Float?
  
  // Recomendaciones
  recommendations String?         // JSON con recomendaciones
  
  // Última actualización
  lastCalculated  DateTime        @default(now())
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([overallScore])
  @@index([probabilityToClose])
}

model SalesPrediction {
