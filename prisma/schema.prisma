  IN_PROGRESS   // En ejecución
  COMPLETED     // Completada
  VALIDATED     // Validada por admin/jefe de obra
  PAID          // Pagada
}

enum GuaranteeType {
  BANK_GUARANTEE   // Aval bancario
  SURETY_INSURANCE // Seguro de caución
  PROMISSORY_NOTE  // Pagaré
  NONE             // Sin garantía
}

enum ContractStatus {
  DRAFT          // Borrador
  PENDING_SIGN   // Pendiente de firma
  SIGNED         // Firmado
  ACTIVE         // Activo
  COMPLETED      // Completado
  CANCELLED      // Cancelado
}

enum PenaltyType {
  DELAY          // Retraso
  INACTIVITY     // Inactividad
  BREACH         // Incumplimiento
  QUALITY        // Calidad deficiente
}

enum SubcontractorTaskStatus {
  ASSIGNED       // Asignada
  IN_PROGRESS    // En progreso
  COMPLETED      // Completada
  VALIDATED      // Validada
  REJECTED       // Rechazada
}

// Perfil extendido de subcontrata
model SubcontractorProfile {
  id                  String          @id @default(cuid())
  userId              String          @unique
  companyId           String?
  
  // Datos de la subcontrata
  businessName        String?         // Razón social
  taxId               String?         // CIF/NIF
  specialty           String?         // Especialidad (electricista, fontanero, etc.)
  skills              String?         // JSON con lista de habilidades
  
  // Documentación
  insuranceExpiration DateTime?       // Seguro de responsabilidad civil
  licenseExpiration   DateTime?       // Licencia/carnet
  
  // Configuración de pagos
  maxAdvancePercent   Float           @default(10)  // Máximo % anticipo permitido
  paymentTerms        Int             @default(30)  // Días de pago
  bankAccount         String?
  
  // Ranking y métricas
  rating              Float           @default(0)   // Valoración 0-5
  totalWorks          Int             @default(0)   // Total de obras
  completedWorks      Int             @default(0)   // Obras completadas
  onTimeRate          Float           @default(0)   // % cumplimiento plazos
  qualityScore        Float           @default(0)   // Puntuación calidad
  
  // Penalizaciones acumuladas
  totalPenalties      Float           @default(0)   // Total penalizaciones en €
  penaltyCount        Int             @default(0)   // Número de penalizaciones
  
  // Estado
  isActive            Boolean         @default(true)
  isVerified          Boolean         @default(false)  // Verificado por admin
  
  // Timestamps
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  
  // Relaciones
  tasks               SubcontractorTask[]
  contracts           SubcontractorContract[]
  paymentPhases       SubcontractorPaymentPhase[]
  advances            SubcontractorAdvance[]
  penalties           SubcontractorPenalty[]
  invoices            SubcontractorInvoice[]
  workLogs            SubcontractorWorkLog[]
  materialDeliveries  MaterialDelivery[]
  rankingHistory      SubcontractorRankingHistory[]
  
  @@index([userId])
  @@index([companyId])
  @@index([rating])
}

// Asignación de tarea a subcontrata
model SubcontractorTask {
  id                  String                  @id @default(cuid())
  workId              String
  subcontractorId     String
  
  // Datos de la tarea
  title               String
  description         String?
  category            String?                 // estructura, cerramientos, instalaciones, etc.
  
  // Fechas
  assignedAt          DateTime                @default(now())
  startDate           DateTime?
  estimatedEndDate    DateTime?
  completedAt         DateTime?
  validatedAt         DateTime?
  
  // Estado
  status              SubcontractorTaskStatus @default(ASSIGNED)
  
  // Importes
  agreedAmount        Float?
  
  // Progreso
  progress            Int                     @default(0)  // 0-100
  
  // Timestamps
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  
  // Relaciones
  work                Work                    @relation(fields: [workId], references: [id], onDelete: Cascade)
  subcontractor       SubcontractorProfile    @relation(fields: [subcontractorId], references: [id])
  validations         TaskValidation[]
  evidences           TaskEvidence[]
  paymentPhases       SubcontractorPaymentPhase[]
  
  @@index([workId])
  @@index([subcontractorId])
  @@index([status])
}

// Evidencias de trabajo (fotos, vídeos)
model TaskEvidence {
  id                  String              @id @default(cuid())
  taskId              String
  uploadedById        String              // Quién sube (subcontrata o validador)
  
  // Datos de la evidencia
  type                String              // photo, video, document
  url                 String              // URL del archivo
  description         String?
  
  // Metadatos
  takenAt             DateTime?           // Fecha/hora de captura
  location            String?             // JSON con coordenadas GPS
  
  // Timestamp
  createdAt           DateTime            @default(now())
  
  // Relaciones
  task                SubcontractorTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@index([taskId])
  @@index([type])
}

// Validación de tarea
model TaskValidation {
  id                  String              @id @default(cuid())
  taskId              String
  validatedById       String              // Admin o jefe de obra
  
  // Datos de validación
  status              String              // approved, rejected, needs_revision
  comments            String?
  
  // Checklist (JSON con items verificados)
  checklistResults    String?
  
  // Timestamps
  createdAt           DateTime            @default(now())
  
  // Relaciones
  task                SubcontractorTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@index([taskId])
  @@index([validatedById])
}

// Fase de pago
model SubcontractorPaymentPhase {
  id                  String              @id @default(cuid())
  taskId              String?
  subcontractorId     String
  workId              String
  
  // Datos de la fase
  name                String              // "Fase 1: Inicio", "Fase 2: Avance 50%", etc.
  description         String?
  phaseOrder          Int                 @default(1)  // Orden de la fase
  
  // Importes
  totalAmount         Float               // Importe total de la fase
  paymentPercent      Float               // % del total que representa
  
  // Estado
  status              PhaseStatus         @default(PENDING)
  
  // Fechas
  startDate           DateTime?
  completedDate       DateTime?
  validatedDate       DateTime?
  paidDate            DateTime?
  
  // Validación
  validatedById       String?
  validationComments String?
  
  // Pago
  paymentReference    String?             // Referencia del pago
  invoiceId           String?             // Factura asociada
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relaciones
  subcontractor       SubcontractorProfile @relation(fields: [subcontractorId], references: [id])
  work                Work                @relation(fields: [workId], references: [id])
  task                SubcontractorTask?  @relation(fields: [taskId], references: [id])
  
  @@index([taskId])
  @@index([subcontractorId])
  @@index([workId])
  @@index([status])
}

// Anticipo controlado
model SubcontractorAdvance {
  id                  String              @id @default(cuid())
  subcontractorId     String
  workId              String
  contractId          String?
  
  // Datos del anticipo
  amount              Float
  percent             Float               // % del total
  reason              String?
  
  // Garantía
  guaranteeType       GuaranteeType       @default(NONE)
  guaranteeDocument   String?             // URL del documento de garantía
  guaranteeExpiration DateTime?
  
  // Estado
  isApproved          Boolean             @default(false)
  approvedById        String?
  approvedAt          DateTime?
  
  // Recuperación
  isRecovered         Boolean             @default(false)
  recoveredAt         DateTime?
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relaciones
  subcontractor       SubcontractorProfile @relation(fields: [subcontractorId], references: [id])
  work                Work                @relation(fields: [workId], references: [id])
  
  @@index([subcontractorId])
  @@index([workId])
  @@index([isApproved])
}

// Contrato inteligente
model SubcontractorContract {
  id                  String              @id @default(cuid())
  subcontractorId     String
  workId              String?
  taskId              String?
  
  // Datos del contrato
  contractNumber      String
  title               String
  description         String?
  
  // Importes
  totalAmount         Float
  currency            String              @default("EUR")
  
  // Fechas
  startDate           DateTime
  endDate             DateTime?
  
  // Cláusulas automáticas (JSON)
  clauses             String?             // JSON con cláusulas configurables
  
  // Penalizaciones automáticas
  delayPenaltyPerDay  Float?              // € por día de retraso
  inactivityPenalty   Float?              // Penalización por inactividad
  breachPenalty       Float?              // Penalización por incumplimiento
  
  // Firma digital
  signedBySubcontractor Boolean          @default(false)
  signedBySubcontractorAt DateTime?
  signedByCompany     Boolean             @default(false)
  signedByCompanyAt   DateTime?
  signedByCompanyId   String?
  
  // Documento
  documentUrl         String?             // PDF del contrato
  
  // Estado
  status              ContractStatus      @default(DRAFT)
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relaciones
  subcontractor       SubcontractorProfile @relation(fields: [subcontractorId], references: [id])
  
  @@index([subcontractorId])
  @@index([workId])
  @@index([status])
}

// Penalización
model SubcontractorPenalty {
  id                  String              @id @default(cuid())
  subcontractorId     String
  workId              String?
  taskId              String?
  contractId          String?
  
  // Datos de la penalización
  type                PenaltyType
  reason              String
  description         String?
  
  // Importe
  amount              Float
  appliedToPaymentId  String?             // ID del pago al que se descontó
  
  // Días/magnitud
  days                Int?                // Días de retraso, etc.
  
  // Estado
  isApplied           Boolean             @default(false)
  appliedAt           DateTime?
  
  // Disputa
  isDisputed          Boolean             @default(false)
  disputeReason       String?
  disputeResolvedAt   DateTime?
  disputeResult       String?
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relaciones
  subcontractor       SubcontractorProfile @relation(fields: [subcontractorId], references: [id])
  
  @@index([subcontractorId])
  @@index([type])
  @@index([isApplied])
}

// Factura de subcontrata (controlada)
model SubcontractorInvoice {
  id                  String              @id @default(cuid())
  subcontractorId     String
  workId              String?
  
  // Datos de factura
  invoiceNumber       String
  issueDate           DateTime
  dueDate             DateTime?
  
  // Importes
  subtotal            Float
  tax                 Float
  taxRate             Float               @default(21)
  total               Float
  
  // Penizaciones aplicadas
  penaltiesDeducted   Float               @default(0)
  
  // Solo se puede generar desde fases aprobadas
  generatedFromPhases String?             // JSON con IDs de fases validadas
  
  // Estado
  status              String              @default("pending") // pending, approved, paid, cancelled
  
  // Pago
  paidAt              DateTime?
  paymentReference    String?
  
  // Documento
  documentUrl         String?
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relaciones
  subcontractor       SubcontractorProfile @relation(fields: [subcontractorId], references: [id])
  
  @@index([subcontractorId])
  @@index([workId])
  @@index([status])
}

// Registro de actividad en obra (fichaje/logística)
model SubcontractorWorkLog {
  id                  String              @id @default(cuid())
  subcontractorId     String
  workId              String
  
  // Tipo de registro
  type                String              // check_in, check_out, delivery, incident
  
  // Datos
  notes               String?
  
  // Ubicación
  latitude            Float?
  longitude           Float?
  
  // Equipos/personas
  teamSize            Int?
  equipment           String?             // JSON con equipos presentes
  
  // Tiempos
  checkInAt           DateTime?
  checkOutAt          DateTime?
  hoursWorked         Float?
  
  // Timestamp
  createdAt           DateTime            @default(now())
  
  // Relaciones
  subcontractor       SubcontractorProfile @relation(fields: [subcontractorId], references: [id])
  work                Work                @relation(fields: [workId], references: [id])
  
  @@index([subcontractorId])
  @@index([workId])
  @@index([type])
  @@index([createdAt])
}

// Entrega de materiales
model MaterialDelivery {
  id                  String              @id @default(cuid())
  subcontractorId     String
  workId              String
  
  // Datos de entrega
  deliveryNumber      String
  supplier            String?
  
  // Contenido (JSON)
  materials           String              // JSON con lista de materiales
  
  // Estado
  status              String              @default("pending") // pending, received, verified
  
  // Fechas
  deliveryDate        DateTime?
  receivedAt          DateTime?
  verifiedAt          DateTime?
  verifiedById        String?
  
  // Documentación
  invoiceUrl          String?             // Factura del proveedor
  photos              String?             // JSON con URLs de fotos
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relaciones
  subcontractor       SubcontractorProfile @relation(fields: [subcontractorId], references: [id])
  work                Work                @relation(fields: [workId], references: [id])
  
  @@index([subcontractorId])
  @@index([workId])
  @@index([status])
}

// Historial de ranking de subcontrata
model SubcontractorRankingHistory {
  id                  String              @id @default(cuid())
  subcontractorId     String
  
  // Período
  period              String              // "2024-01", "2024-Q1", etc.
  periodType          String              // monthly, quarterly, yearly
  
  // Métricas del período
  worksCompleted      Int                 @default(0)
  worksOnTime         Int                 @default(0)
  averageQuality      Float               @default(0)
  totalPenalties      Float               @default(0)
  
  // Puntuación
  score               Float               @default(0)
  rank                Int?
  
  // Timestamp
  createdAt           DateTime            @default(now())
  
  // Relaciones
  subcontractor       SubcontractorProfile @relation(fields: [subcontractorId], references: [id])
  
  @@index([subcontractorId])
  @@index([period])
}

// Plantilla de contrato
model ContractTemplate {
  id                  String              @id @default(cuid())
  companyId           String
  
  // Datos
  name                String
  description         String?
  
  // Contenido
  content             String              // HTML del contrato
  clauses             String?             // JSON con cláusulas por defecto
  
  // Configuración de penalizaciones por defecto
  defaultDelayPenalty Float?
  defaultInactivityPenalty Float?
  defaultBreachPenalty Float?
  
  // Estado
  isActive            Boolean             @default(true)
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  @@index([companyId])
}

// Checklist de validación por fase
model ValidationChecklist {
  id                  String              @id @default(cuid())
  companyId           String
  
  // Datos
  name                String
  category            String              // estructura, cerramientos, instalaciones, etc.
  description         String?
  
  // Items del checklist (JSON)
  items               String              // JSON con [{id, label, required, type}]
  
  // Estado
  isActive            Boolean             @default(true)
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  @@index([companyId])
  @@index([category])
}

// ==========================================
// ASISTENTE AI INTEGRADO
// ==========================================

model AIChatSession {
  id                  String              @id @default(cuid())
  userId              String
  
  // Datos de la sesión
  title               String?             // Título opcional de la conversación
  
  // Contexto
  context             String?             // JSON con contexto del CRM (lead actual, obra, etc.)
  
  // Estado
  isActive            Boolean             @default(true)
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relaciones
  messages            AIChatMessage[]
  
  @@index([userId])
  @@index([createdAt])
}

model AIChatMessage {
  id                  String              @id @default(cuid())
  sessionId           String
  
  // Remitente
  role                String              // "user" o "assistant"
  
  // Contenido
  content             String
  
  // Metadata
  metadata            String?             // JSON con información adicional (tokens, modelo, etc.)
  
  // Timestamp
  createdAt           DateTime            @default(now())
  
  // Relaciones
  session             AIChatSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
  @@index([createdAt])
}

// ==========================================
// CONTROL DE HORAS DE TRABAJADORES
// ==========================================

enum TimeEntryType {
  WORK            // Trabajo normal
  OVERTIME        // Horas extra
  VACATION        // Vacaciones
  SICK_LEAVE      // Baja médica
  HOLIDAY         // Festivo
  PERMISSION      // Permiso
}

model WorkerTimeLog {
  id              String          @id @default(cuid())
  userId          String
  companyId       String
  workId          String?         // Obra asignada (opcional)
  
  // Tipo de entrada
  type            TimeEntryType   @default(WORK)
  
  // Fechas y horas
  date            DateTime        // Fecha del trabajo
  checkIn         DateTime?       // Hora de entrada
  checkOut        DateTime?       // Hora de salida
  
  // Horas calculadas
  hoursWorked     Float           @default(0)
  overtimeHours   Float           @default(0)
  
  // Ubicación del fichaje
  checkInLocation String?         // JSON con coordenadas
  checkOutLocation String?        // JSON con coordenadas
  
  // Notas
  notes           String?
  
  // Aprobación
  isApproved      Boolean         @default(false)
  approvedById    String?
  approvedAt      DateTime?
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([userId])
  @@index([companyId])
  @@index([workId])
  @@index([date])
  @@index([type])
}

model WorkerSchedule {
  id              String          @id @default(cuid())
  userId          String          @unique
  companyId       String
  
  // Horario semanal (JSON)
  weeklySchedule  String          // JSON con horarios por día
  
  // Jornada
  workHoursPerDay Float           @default(8)
  workDaysPerWeek Int             @default(5)
  
  // Festivos y vacaciones
  vacationDays    Int             @default(22)
  usedVacationDays Int            @default(0)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([companyId])
}

model WorkerLocation {
  id              String          @id @default(cuid())
  userId          String
  workId          String?
  
  // Ubicación
  latitude        Float
  longitude       Float
  accuracy        Float?
  
  // Timestamp
  recordedAt      DateTime        @default(now())
  
  @@index([userId])
  @@index([workId])
  @@index([recordedAt])
}

// ==========================================
// PROYECTOS ARQUITECTÓNICOS
// ==========================================

enum ProjectStatus {
  DRAFT          // Borrador
  IN_DESIGN      // En diseño
  FOR_REVIEW     // Pendiente de revisión
  APPROVED       // Aprobado
  IN_CONSTRUCTION // En construcción
  COMPLETED      // Completado
  ARCHIVED       // Archivado
}

enum PlanType {
  FLOOR_PLAN     // Plano de planta
  ELEVATION      // Alzado
  SECTION        // Sección
  ELECTRICAL     // Instalación eléctrica
  PLUMBING       // Fontanería
  STRUCTURE      // Estructura
  LANDSCAPE      // Jardinería
  THREED_MODEL       // Modelo 3D
  RENDER         // Render
  OTHER          // Otro
}

model ArchitectProject {
  id              String          @id @default(cuid())
  companyId       String
  createdById     String          // Arquitecto creador
  workId          String?         // Obra asociada (si ya existe)
  leadId          String?         // Lead asociado
  
  // Datos del proyecto
  name            String
  description     String?
  reference       String?         // Referencia interna
  location        String?
  
  // Estado
  status          ProjectStatus   @default(DRAFT)
  
  // Datos del cliente
  clientName      String?
  clientPhone     String?
  clientEmail     String?
  
  // Especificaciones
  totalArea       Float?          // m² totales
  floors          Int?            // Número de plantas
  bedrooms        Int?
  bathrooms       Int?
  
  // Fechas
  startDate       DateTime?
  estimatedEndDate DateTime?
  completedAt     DateTime?
  
  // Visibilidad para cliente
  visibleToClient Boolean         @default(false)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  plans           ProjectPlan[]
  comments        ProjectComment[]
  approvals       ProjectApproval[]
  
  @@index([companyId])
  @@index([createdById])
  @@index([status])
  @@index([workId])
}

model ProjectPlan {
  id              String          @id @default(cuid())
  projectId       String
  uploadedById    String          // Arquitecto que sube
  
  // Datos del plano
  name            String
  description     String?
  type            PlanType        @default(FLOOR_PLAN)
  floor           Int?            // Planta (0=baja, 1=primera, etc.)
  scale           String?         // Escala (1:100, etc.)
  
  // Archivo
  fileName        String
  filePath        String          // URL del archivo
  fileSize        Int?
  mimeType        String?
  
  // Versionado
  version         Int             @default(1)
  parentPlanId    String?         // Para versiones anteriores
  
  // Dimensiones del plano
  width           Float?          // Ancho en metros
  height          Float?          // Alto en metros
  
  // Estado
  isActive        Boolean         @default(true)
  
  // Visibilidad
  visibleToClient Boolean         @default(false)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  project         ArchitectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([type])
  @@index([uploadedById])
}

model ProjectComment {
  id              String          @id @default(cuid())
  projectId       String
  userId          String
  planId          String?         // Comentario en un plano específico
  
  // Contenido
  content         String
  
  // Posición en el plano (si aplica)
  positionX       Float?
  positionY       Float?
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  project         ArchitectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([userId])
  @@index([planId])
}

model ProjectApproval {
  id              String          @id @default(cuid())
  projectId       String
  approvedById    String          // Usuario que aprueba
  
  // Datos
  status          String          @default("pending") // pending, approved, rejected
  comments        String?
  
  // Timestamps
  createdAt       DateTime        @default(now())
  decidedAt       DateTime?
  
  // Relaciones
  project         ArchitectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([approvedById])
}

// ==========================================
// ASIGNACIONES DIRECTAS A USUARIOS
// ==========================================

model DirectAssignment {
  id              String          @id @default(cuid())
  companyId       String
  assignedToId    String          // Usuario que recibe la asignación
  assignedById    String          // Usuario que asigna
  
  // Tipo de entidad asignada
  entityType      String          // lead, work, task, project, plan
  entityId        String
  
  // Datos
  priority        Int             @default(3)  // 1=Urgente, 2=Alta, 3=Normal
  notes           String?
  
  // Fechas
  dueDate         DateTime?
  completedAt     DateTime?
  
  // Estado
  status          String          @default("pending") // pending, accepted, in_progress, completed, cancelled
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([companyId])
  @@index([assignedToId])
  @@index([entityType])
  @@index([entityId])
}

// ==========================================
// CATÁLOGO DE MATERIALES Y ACABADOS
// ==========================================

enum MaterialTypeEnum {
  STRUCTURAL     // Estructural
  FINISHES       // Acabados
  ELECTRICAL     // Eléctrico
  PLUMBING       // Fontanería
  INSULATION     // Aislamiento
  FLOORING       // Suelos
  WALLS          // Paredes
  CEILING        // Techos
  DOORS          // Puertas
  WINDOWS        // Ventanas
  KITCHEN        // Cocina
  BATHROOM       // Baño
  OUTDOOR        // Exterior
  OTHER          // Otro
}

enum MaterialStatus {
  ACTIVE         // Activo
  DISCONTINUED   // Descatalogado
  OUT_OF_STOCK   // Sin stock
  LIMITED        // Limitado
}

model ProductCategory {
  id              String          @id @default(cuid())
  companyId       String
  parentId        String?         // Para categorías anidadas
  
  // Datos
  name            String
  description     String?
  icon            String?         // Emoji o nombre de icono
  color           String?         // Color para UI
  
  // Orden
  order           Int             @default(0)
  
  // Estado
  isActive        Boolean         @default(true)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  materials       MaterialProduct[]
  children        ProductCategory[]  @relation("CategoryHierarchy")
  parent          ProductCategory?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  
  @@index([companyId])
  @@index([parentId])
}

model MaterialProduct {
  id              String          @id @default(cuid())
  companyId       String
  categoryId      String?
  
  // Identificación
  sku             String?         // Código interno
  reference       String?         // Referencia proveedor
  barcode         String?         // Código de barras
  
  // Datos básicos
  name            String
  description     String?
  brand           String?         // Marca
  model           String?         // Modelo
  
  // Categorización
  materialType    MaterialTypeEnum @default(FINISHES)
  tags            String?         // JSON con tags
  
  // Especificaciones
  unit            String          @default("unidad") // unidad, m, m2, m3, kg, litro, pack
  unitQuantity    Float?          // Cantidad por unidad (ej: 2.5m por pieza)
  minOrder        Float?          // Pedido mínimo
  increment       Float?          // Incremento de pedido
  
  // Dimensiones
  length          Float?          // Largo en metros
  width           Float?          // Ancho en metros  
  height          Float?          // Alto en metros
  weight          Float?          // Peso en kg
  
  // Precios
  costPrice       Float?          // Precio de coste
  retailPrice     Float?          // PVP
  contractorPrice Float?          // Precio subcontratas
  priceUnit       String          @default("unidad")
  
  // IVA
  taxRate         Float           @default(21)
  
  // Stock
  stockQuantity   Float           @default(0)
  minStock        Float?          // Stock mínimo
  maxStock        Float?          // Stock máximo
  
  // Estado
  status          MaterialStatus  @default(ACTIVE)
  isActive        Boolean         @default(true)
  isFeatured      Boolean         @default(false)
  
  // Imágenes
  imageUrl        String?
  images          String?         // JSON con array de URLs
  
  // Ficha técnica
  datasheetUrl    String?         // URL PDF ficha técnica
  
  // Proveedor
  supplierId      String?
  supplierName    String?
  leadTime        Int?            // Días de entrega
  
  // Notas internas
  internalNotes   String?
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  categoryRelation ProductCategory? @relation(fields: [categoryId], references: [id])
  orderItems      MaterialOrderItem[]
  priceHistory    MaterialPriceHistory[]
  
  @@index([companyId])
  @@index([materialType])
  @@index([sku])
  @@index([status])
}

model MaterialPriceHistory {
  id              String          @id @default(cuid())
  productId       String
  
  // Datos
  costPrice       Float?
  retailPrice     Float?
  contractorPrice Float?
  
  // Motivo del cambio
  reason          String?
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  product         MaterialProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([productId])
  @@index([createdAt])
}

// ==========================================
// CATÁLOGO DE MERCHANDISING
// ==========================================

enum MerchCategory {
  BRANDED         // Marca
  PROMOTIONAL     // Promocional
  GIFT            // Regalo
  UNIFORM         // Uniforme
  SIGNAGE         // Señalética
  PRINTED         // Impreso
  DIGITAL         // Digital
  OTHER           // Otro
}

model MerchProduct {
  id              String          @id @default(cuid())
  companyId       String
  
  // Identificación
  sku             String?
  reference       String?
  
  // Datos básicos
  name            String
  description     String?
  
  // Categorización
  category        MerchCategory   @default(BRANDED)
  
  // Especificaciones
  unit            String          @default("unidad")
  minOrder        Int?
  
  // Precios - Para inmobiliarias y colaboradores
  costPrice       Float?
  wholesalePrice  Float?          // Precio mayorista
  retailPrice     Float?
  
  // IVA
  taxRate         Float           @default(21)
  
  // Stock
  stockQuantity   Int             @default(0)
  
  // Estado
  isActive        Boolean         @default(true)
  
  // Visibilidad
  visibleToRealEstate Boolean    @default(true)
  visibleToPartners    Boolean    @default(true)
  visibleToFranchises  Boolean    @default(true)
  
  // Imágenes
  imageUrl        String?
  images          String?
  
  // Proveedor
  supplierId      String?
  supplierName    String?
  
  // Personalización
  customizable    Boolean         @default(false)
  customizationOptions String?    // JSON con opciones (talla, color, logo, etc.)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  orderItems      MerchOrderItem[]
  
  @@index([companyId])
  @@index([category])
  @@index([isActive])
}

// ==========================================
// PEDIDOS DE MATERIALES
// ==========================================

enum MaterialOrderStatus {
  DRAFT           // Borrador
  PENDING         // Pendiente aprobación
  APPROVED        // Aprobado
  ORDERED         // Pedido al proveedor
  PARTIAL         // Entrega parcial
  DELIVERED       // Entregado
  CANCELLED       // Cancelado
}

enum MaterialOrderType {
  INTERNAL        // Uso interno
  SUBCONTRACTOR   // Para subcontrata
  PROJECT         // Para obra específica
  STOCK           // Reposición stock
}

model MaterialOrder {
  id              String              @id @default(cuid())
  companyId       String
  orderNumber     String              // Número de pedido
  
  // Tipo
  type            MaterialOrderType   @default(INTERNAL)
  
  // Solicitante
  requestedById   String              // Usuario que solicita
  subcontractorId String?             // Si es pedido de subcontrata
  workId          String?             // Obra asociada
  
  // Proveedor
  supplierId      String?
  supplierName    String?
  supplierContact String?
  supplierPhone   String?
  supplierEmail   String?
  
  // Dirección de entrega
  deliveryAddress String?
  deliveryCity    String?
  deliveryPostalCode String?
  deliveryNotes   String?
  
  // Fechas
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  deliveryDate    DateTime?
  
  // Estado
  status          MaterialOrderStatus @default(DRAFT)
  
  // Importes
  subtotal        Float               @default(0)
  tax             Float               @default(0)
  total           Float               @default(0)
  discount        Float               @default(0)
  
  // Aprobación
  approvedById    String?
  approvedAt      DateTime?
  approvalNotes   String?
  
  // Notas
  notes           String?
  internalNotes   String?
  
  // Documentos
  purchaseOrderUrl String?            // PDF pedido compra
  deliveryNoteUrl  String?            // Albarán
  
  // Timestamps
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  work            Work?           @relation(fields: [workId], references: [id])
  items           MaterialOrderItem[]
  
  @@index([companyId])
  @@index([status])
  @@index([requestedById])
  @@index([workId])
}

model MaterialOrderItem {
  id              String          @id @default(cuid())
  orderId         String
  productId       String?
  
  // Datos del producto (desnormalizado)
  productName     String
  productSku      String?
  productUnit     String
  
  // Cantidad y precio
  quantity        Float
  unitPrice       Float
  taxRate         Float           @default(21)
  discount        Float           @default(0)
  total           Float
  
  // Entrega
  deliveredQty    Float           @default(0)
  pendingQty      Float?          // Calculado: quantity - deliveredQty
  
  // Notas
  notes           String?
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  order           MaterialOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         MaterialProduct? @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([productId])
}

// ==========================================
// PEDIDOS DE MERCHANDISING
// ==========================================

enum MerchOrderStatus {
  DRAFT           // Borrador
  PENDING         // Pendiente
  PROCESSING      // En proceso
  SHIPPED         // Enviado
  DELIVERED       // Entregado
  CANCELLED       // Cancelado
}

model MerchOrder {
  id              String            @id @default(cuid())
  companyId       String
  orderNumber     String
  
  // Cliente (inmobiliaria, colaborador, franquicia)
  clientId        String?           // User ID del cliente
  clientType      String?           // REAL_ESTATE, FRANCHISE, PARTNER
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientCompany   String?
  
  // Dirección de envío
  shippingAddress String?
  shippingCity    String?
  shippingPostalCode String?
  shippingProvince String?
  
  // Fechas
  orderDate       DateTime          @default(now())
  shipDate        DateTime?
  deliveryDate    DateTime?
  
  // Estado
  status          MerchOrderStatus  @default(DRAFT)
  
  // Importes
  subtotal        Float             @default(0)
  tax             Float             @default(0)
  shipping        Float             @default(0)
  total           Float             @default(0)
  
  // Seguimiento
