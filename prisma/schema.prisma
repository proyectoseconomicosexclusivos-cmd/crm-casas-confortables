  // Relaciones
  order           MerchOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         MerchProduct?   @relation(fields: [productId], references: [id])
  
  @@index([orderId])
}

// ==========================================
// CERTIFICACIONES
// ==========================================

enum CertificationStatus {
  DRAFT           // Borrador
  PENDING         // Pendiente revisión
  APPROVED        // Aprobado
  PARTIAL         // Certificación parcial
  FINAL           // Certificación final
  INVOICED        // Facturado
  PAID            // Pagado
}

model Certification {
  id              String              @id @default(cuid())
  companyId       String
  workId          String
  clientId        String?             // Usuario cliente
  
  // Datos
  number          String              // Número de certificación
  type            String              @default("partial") // partial, final, monthly
  period          String?             // Período (ej: "2024-01")
  
  // Fechas
  certDate        DateTime            @default(now())
  fromDate        DateTime?
  toDate          DateTime?
  
  // Estado
  status          CertificationStatus @default(DRAFT)
  
  // Importes
  previousCertified Float             @default(0)  // Lo certificado anteriormente
  currentCertified  Float             @default(0)  // Lo certificado ahora
  totalCertified    Float             @default(0)  // Acumulado
  retentionPct      Float             @default(0)  // % de retención
  retentionAmount   Float             @default(0)  // Importe retenido
  subtotal          Float             @default(0)
  tax               Float             @default(0)
  total             Float             @default(0)
  
  // Aprobación
  approvedById    String?
  approvedAt      DateTime?
  
  // Factura
  invoiceNumber   String?
  invoiceDate     DateTime?
  invoiceUrl      String?
  
  // Pago
  paidAt          DateTime?
  paymentMethod   String?
  
  // Notas
  notes           String?
  
  // PDF
  pdfUrl          String?
  
  // Timestamps
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  work            Work            @relation(fields: [workId], references: [id])
  items           CertificationItem[]
  
  @@index([companyId])
  @@index([workId])
  @@index([status])
}

model CertificationItem {
  id              String          @id @default(cuid())
  certificationId String
  
  // Datos de la partida
  concept        String
  description    String?
  unit           String
  budgetQty      Float           // Cantidad presupuestada
  previousQty    Float           // Certificado anteriormente
  currentQty     Float           // Certificado ahora
  unitPrice      Float
  budgetAmount   Float           // Importe presupuestado
  previousAmount Float           // Importe anterior
  currentAmount  Float           // Importe actual
  
  // Timestamps
  createdAt      DateTime        @default(now())
  
  // Relaciones
  certification  Certification   @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  
  @@index([certificationId])
}

// ==========================================
// CONTROL DE PRESUPUESTOS SUBCONTRATAS
// ==========================================

enum SubcontractorBudgetStatus {
  DRAFT           // Borrador
  PENDING         // Pendiente aprobación
  ACCEPTED        // Aceptado
  REJECTED        // Rechazado
  IN_PROGRESS     // En ejecución
  COMPLETED       // Completado
  CANCELLED       // Cancelado
}

model SubcontractorBudget {
  id              String                  @id @default(cuid())
  companyId       String
  workId          String
  subcontractorId String
  
  // Datos
  number          String?
  title           String
  description     String?
  
  // Fechas
  budgetDate      DateTime                @default(now())
  validUntil      DateTime?
  startDate       DateTime?
  endDate         DateTime?
  
  // Estado
  status          SubcontractorBudgetStatus @default(DRAFT)
  
  // Importes
  subtotal        Float                   @default(0)
  tax             Float                   @default(0)
  total           Float                   @default(0)
  
  // Control de márgenes
  clientBudget    Float?                  // Presupuesto al cliente
  margin          Float?                  // Margen calculado
  marginPct       Float?                  // % de margen
  
  // Anteriores (para comparar cambios)
  previousBudgetId String?
  previousTotal   Float?
  difference      Float?                  // Diferencia con anterior
  
  // Aprobación
  acceptedAt      DateTime?
  acceptedById    String?
  
  // Notas
  notes           String?
  
  // Timestamps
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  work            Work            @relation(fields: [workId], references: [id])
  items           SubcontractorBudgetItem[]
  certifications  SubcontractorCertification[]
  comparisons     BudgetComparison[]
  
  @@index([companyId])
  @@index([workId])
  @@index([subcontractorId])
  @@index([status])
}

model SubcontractorBudgetItem {
  id              String                  @id @default(cuid())
  budgetId        String
  
  // Datos
  concept        String
  description    String?
  unit           String
  quantity       Float
  unitPrice      Float
  total          Float
  
  // Control
  certifiedQty   Float                   @default(0)
  pendingQty     Float
  certifiedAmount Float                  @default(0)
  
  // Timestamps
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  
  // Relaciones
  budget         SubcontractorBudget     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  
  @@index([budgetId])
}

model SubcontractorCertification {
  id              String          @id @default(cuid())
  budgetId        String
  
  // Datos
  number          String
  certDate        DateTime        @default(now())
  period          String?
  
  // Importes
  previousAmount  Float           @default(0)
  currentAmount   Float           @default(0)
  totalAmount     Float           @default(0)
  
  // Estado
  status          String          @default("pending") // pending, approved, paid
  
  // Pago
  paidAt          DateTime?
  paymentMethod   String?
  
  // Notas
  notes           String?
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  budget          SubcontractorBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  
  @@index([budgetId])
  @@index([status])
}

// ==========================================
// ANÁLISIS Y COMPARACIÓN DE PRESUPUESTOS
// ==========================================

model BudgetComparison {
  id              String          @id @default(cuid())
  workId          String
  newBudgetId     String
  oldBudgetId     String?
  
  // Datos del cambio
  changedById     String          // Usuario que hizo el cambio
  subcontractorBefore String?     // Subcontrata anterior
  subcontractorAfter String?      // Subcontrata nueva
  
  // Importes
  amountBefore    Float
  amountAfter     Float
  difference      Float
  differencePct   Float
  
  // Margen
  marginBefore    Float?
  marginAfter     Float?
  marginImprovement Float?
  
  // Profit Share calculado
  profitShareAmount Float?
  profitSharePct  Float?
  
  // Análisis IA
  aiAnalysis      String?         // Análisis de la IA
  aiRecommendations String?       // Recomendaciones
  
  // Fecha
  createdAt       DateTime        @default(now())
  
  // Relaciones
  work            Work            @relation(fields: [workId], references: [id])
  newBudget       SubcontractorBudget @relation(fields: [newBudgetId], references: [id])
  
  @@index([workId])
  @@index([changedById])
  @@index([createdAt])
}

// ==========================================
// PROFIT SHARE - REPARTO DE BENEFICIOS
// ==========================================

enum ProfitShareStatus {
  CALCULATED      // Calculado
  PENDING         // Pendiente aprobación
  APPROVED        // Aprobado
  PAID            // Pagado
  CANCELLED       // Cancelado
}

model ProfitShare {
  id              String              @id @default(cuid())
  companyId       String
  workId          String?
  budgetComparisonId String?
  
  // Beneficiario
  userId          String              // Empleado que obtiene el profit
  userName        String
  
  // Origen del beneficio
  source          String              // budget_optimization, negotiation, supplier_change
  description     String
  
  // Cálculo
  savingAmount    Float               // Ahorro total conseguido
  sharePct        Float               // % que le corresponde
  shareAmount     Float               // Cantidad a recibir
  
  // Estado
  status          ProfitShareStatus   @default(CALCULATED)
  
  // Aprobación
  approvedById    String?
  approvedAt      DateTime?
  
  // Pago
  paidAt          DateTime?
  paymentRef      String?             // Referencia del pago
  
  // Notas
  notes           String?
  
  // Timestamps
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  work            Work?           @relation(fields: [workId], references: [id])
  
  @@index([companyId])
  @@index([userId])
  @@index([workId])
  @@index([status])
}

// ==========================================
// IMPORTACIÓN DE CATÁLOGOS (PDF)
// ==========================================

model CatalogImport {
  id              String          @id @default(cuid())
  companyId       String
  uploadedById    String
  
  // Tipo
  type            String          // materials, merch
  
  // Archivo
  fileName        String
  filePath        String
  fileSize        Int?
  
  // Estado
  status          ImportStatus    @default(PENDING)
  processedRows   Int             @default(0)
  totalRows       Int?
  errorRows       Int             @default(0)
  
  // Resultado
  productsCreated Int             @default(0)
  productsUpdated Int             @default(0)
  errors          String?         // JSON con errores
  
  // Configuración de importación
  config          String?         // JSON con mapeo de columnas
  
  // Timestamps
  createdAt       DateTime        @default(now())
  completedAt     DateTime?
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  drafts          ImportedProductDraft[]
  
  @@index([companyId])
  @@index([status])
}

model ImportedProductDraft {
  id              String          @id @default(cuid())
  importId        String
  
  // Datos crudos del PDF
  rawData         String          // JSON con datos extraídos
  
  // Datos procesados
  name            String?
  sku             String?
  description     String?
  unit            String?
  category        String?
  
  // Precio (pendiente de asignar)
  price           Float?
  hasPrice        Boolean         @default(false)
  
  // Estado
  isProcessed     Boolean         @default(false)
  isApproved      Boolean         @default(false)
  productId       String?         // ID del producto creado
  
  // Timestamps
  createdAt       DateTime        @default(now())
  processedAt     DateTime?
  
  // Relaciones
  import          CatalogImport   @relation(fields: [importId], references: [id], onDelete: Cascade)
  
  @@index([importId])
  @@index([isProcessed])
}

// ==========================================
// CERTIFICACIONES DE EMPLEADOS
// ==========================================

enum EmployeeCertificationStatus {
  DRAFT          // Borrador
  SUBMITTED      // Enviado por empleado
  APPROVED       // Aprobado
  PAID           // Pagado
  REJECTED       // Rechazado
}

model EmployeeCertification {
  id              String                      @id @default(cuid())
  companyId       String
  userId          String                      // Empleado
  workId          String?                     // Obra relacionada
  
  // Período
  month           Int                         // 1-12
  year            Int
  
  // Datos del empleado
  amount          Float                       // Cantidad certificada por el empleado
  workDescription String?                     // Descripción del trabajo realizado
  hoursWorked     Float?                      // Horas trabajadas
  
  // Validación admin
  adminAmount     Float?                      // Cantidad validada por admin
  adminNotes      String?
  validatedById   String?
  validatedAt     DateTime?
  
  // Cálculo de profit
  profitAmount    Float?                      // Profit calculado
  profitPct       Float?                      // Porcentaje de profit
  
  // Estado
  status          EmployeeCertificationStatus @default(DRAFT)
  
  // Pago
  paidAt          DateTime?
  paymentRef      String?
  
  // Timestamps
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  
  // Relaciones
  company         Company                     @relation(fields: [companyId], references: [id])
  user            User                        @relation(fields: [userId], references: [id])
  items           EmployeeCertificationItem[]
  
  @@unique([userId, month, year])              // Una certificación por mes/año/empleado
  @@index([companyId])
  @@index([userId])
  @@index([workId])
  @@index([status])
  @@index([year, month])
}

model EmployeeCertificationItem {
  id                  String    @id @default(cuid())
  certificationId     String
  
  // Datos
  workId              String?   // Obra específica
  workName            String?   // Nombre de la obra
  description         String    // Descripción del trabajo
  hours               Float     // Horas dedicadas
  amount              Float     // Cantidad
  
  // Validación
  validatedAmount     Float?    // Cantidad validada
  notes               String?
  
  // Timestamps
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relaciones
  certification       EmployeeCertification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  
  @@index([certificationId])
  @@index([workId])
}

// ==========================================
// CONTRATOS
// ==========================================

enum ContractType {
  CLIENT         // Contrato con cliente
  SUBCONTRACTOR  // Contrato con subcontrata
  REAL_ESTATE    // Contrato con inmobiliaria
  PARTNER        // Contrato con colaborador
  EMPLOYEE       // Contrato laboral
  SUPPLIER       // Contrato con proveedor
}

enum MainContractStatus {
  DRAFT          // Borrador
  PENDING_SIGN   // Pendiente de firma
  ACTIVE         // Activo
  COMPLETED      // Completado
  CANCELLED      // Cancelado
  EXPIRED        // Expirado
}

model Contract {
  id              String              @id @default(cuid())
  companyId       String
  
  // Tipo
  type            ContractType
  number          String          // Número de contrato
  
  // Partes
  partyType       String          // client, subcontractor, real_estate, partner
  partyId         String?         // ID del usuario/empresa
  partyName       String          // Nombre de la otra parte
  partyTaxId      String?         // CIF/NIF
  partyAddress    String?
  partyPhone      String?
  partyEmail      String?
  
  // Relación con obra/lead
  workId          String?
  leadId          String?
  
  // Datos del contrato
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime?
  
  // Importes
  totalAmount     Float?
  currency        String          @default("EUR")
  paymentTerms    String?         // JSON con condiciones de pago
  
  // Cláusulas (JSON)
  clauses         String?
  
  // Archivos
  documentUrl     String?         // PDF del contrato
  signedDocumentUrl String?       // PDF firmado
  
  // Firmas
  signedByParty   Boolean         @default(false)
  signedByPartyAt DateTime?
  signedByCompany Boolean         @default(false)
  signedByCompanyAt DateTime?
  signedByCompanyId String?
  
  // Estado
  status          MainContractStatus  @default(DRAFT)
  
  // Renovación
  autoRenew       Boolean         @default(false)
  renewalPeriod   Int?            // Meses de renovación
  
  // Notas
  notes           String?
  internalNotes   String?
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  signedByUser    User?           @relation("ContractsSignedByUser", fields: [signedByCompanyId], references: [id])
  
  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([partyId])
  @@index([workId])
}

// ==========================================
// GESTIÓN DOCUMENTAL AVANZADA
// ==========================================

enum DocumentCategory {
  FLYER          // Flyer promocional
  LOGO           // Logo
  CATALOG        // Catálogo
  MANUAL         // Manual
  TEMPLATE       // Plantilla
  PRESENTATION   // Presentación
  BUDGET_TEMPLATE // Plantilla de presupuesto
  CONTRACT_TEMPLATE // Plantilla de contrato
  CERTIFICATE    // Certificado
  INVOICE        // Factura
  RECEIPT        // Recibo
  OTHER          // Otro
}

model DocumentLibrary {
  id              String            @id @default(cuid())
  companyId       String
  uploadedById    String
  
  // Clasificación
  category        DocumentCategory  @default(OTHER)
  name            String
  description     String?
  tags            String?           // JSON con tags
  
  // Archivo
  fileName        String
  filePath        String
  fileSize        Int?
  mimeType        String?
  
  // Versión
  version         Int               @default(1)
  parentDocumentId String?          // Para versiones anteriores
  
  // Visibilidad
  isPublic        Boolean           @default(false)
  visibleToRoles  String?           // JSON con roles que pueden verlo
  
  // Descargas
  downloadCount   Int               @default(0)
  
  // Metadatos adicionales
  metadata        String?           // JSON con metadatos
  
  // Estado
  isActive        Boolean           @default(true)
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relaciones
  company         Company           @relation(fields: [companyId], references: [id])
  uploadedBy      User              @relation(fields: [uploadedById], references: [id])
  
  @@index([companyId])
  @@index([category])
  @@index([uploadedById])
}

// ==========================================
// ENLACES EXTERNOS (CALCULADORAS)
// ==========================================

model ExternalLink {
  id              String          @id @default(cuid())
  companyId       String
  
  // Datos
  name            String
  description     String?
  url             String
  category        String          // calculator, tool, resource, etc.
  
  // Visibilidad
  visibleToRoles  String?         // JSON con roles
  isPublic        Boolean         @default(false)
  
  // Orden
  order           Int             @default(0)
  
  // Estado
  isActive        Boolean         @default(true)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([category])
}

// ==========================================
// ANÁLISIS DE DOCUMENTOS CON IA
// ==========================================

model DocumentAnalysis {
  id              String          @id @default(cuid())
  companyId       String
  userId          String
  documentId      String?         // Documento analizado (opcional)
  
  // Tipo de análisis
  analysisType    String          // budget, contract, product_list, etc.
  
  // Archivo
  fileName        String
  filePath        String?
  
  // Resultados
  extractedData   String?         // JSON con datos extraídos
  aiSummary       String?         // Resumen del AI
  aiRecommendations String?       // Recomendaciones
  
  // Estado
  status          String          @default("pending") // pending, processing, completed, failed
  
  // Timestamps
  createdAt       DateTime        @default(now())
  completedAt     DateTime?
  
  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  
  @@index([companyId])
  @@index([userId])
  @@index([status])
}
