model MerchOrderItem {
  id              String          @id @default(cuid())
  orderId         String
  productId       String?
  
  // Datos del producto
  productName     String
  productSku      String?
  
  // Cantidad y precio
  quantity        Int
  unitPrice       Float
  taxRate         Float           @default(21)
  total           Float
  
  // Personalización
