model ProductionTimeline {
  id              String          @id @default(cuid())
  productionOrderId String
  userId          String?
  
  // Evento
  event           String          // created, status_change, phase_change, note, etc.
  description     String
  oldValue        String?
  newValue        String?
  
  // Metadata
  metadata        String?         // JSON con información adicional
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  
  @@index([productionOrderId])
  @@index([createdAt])
}

model ProductionPhoto {
  id              String          @id @default(cuid())
  productionOrderId String
  uploadedById    String
  
  // Datos de la foto
  title           String?
  description     String?
  url             String          // URL de la imagen
  
  // Tipo
  type            String          @default("production") // production, quality, loading, delivery
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  // Relaciones
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  
  @@index([productionOrderId])
  @@index([type])
}

// ==========================================
// SISTEMA DE COMISIONES
// ==========================================

enum CommissionStatus {
  PENDING        // Pendiente de cobro
  APPROVED       // Aprobada
  PAID           // Pagada
  CANCELLED      // Cancelada
}

enum CommissionType {
  SALE           // Por venta
  MARGIN         // Por margen
  REFERRAL       // Por referido
  BONUS          // Bonus extra
  FRANCHISE      // Franquicia
  REAL_ESTATE    // Inmobiliaria
}

model CommissionConfig {
  id              String          @id @default(cuid())
  companyId       String
  
  // Ámbito de la comisión
  userId          String?         // Para comercial específico
  roleId          String?         // Para rol (COMMERCIAL, FRANCHISE, etc.)
  
  // Tipo de cálculo
  type            CommissionType  @default(SALE)
  
  // Valores
  percentage      Float?          // Porcentaje de comisión
  fixedAmount     Float?          // Cantidad fija
  
  // Condiciones
  minAmount       Float?          // Importe mínimo
  maxAmount       Float?          // Importe máximo
  validFrom       DateTime?
  validUntil      DateTime?
  
  // Estado
  isActive        Boolean         @default(true)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([companyId])
  @@index([userId])
}

model Commission {
  id              String          @id @default(cuid())
  companyId       String
  
  // Beneficiario
  userId          String          // Usuario que recibe la comisión
  
  // Origen de la comisión
  leadId          String?         // Lead que generó la comisión
  workId          String?         // Obra relacionada
  budgetId        String?         // Presupuesto relacionado
  
  // Tipo y cálculo
  type            CommissionType  @default(SALE)
  baseAmount      Float           // Importe base de la venta
  percentage      Float?          // Porcentaje aplicado
  amount          Float           // Cantidad de comisión
  
